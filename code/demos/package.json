{
  "name": "@tamagui/demos",
  "version": "2.0.0-rc.26-1773871134131",
  "source": "demos/src/index.tsx",
  "files": [
    "src",
    "types",
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./src",
  "exports": {
    "./package.json": "./package.json",
    "./photo/*": "./public/*.jpg",
    ".": {
      "types": "./src/index.tsx",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./demo/*": {
      "types": "./types/*.d.ts",
      "react-native": "./dist/esm/*.native.js",
      "browser": "./dist/esm/*.mjs",
      "module": "./dist/esm/*.mjs",
      "import": "./dist/esm/*.mjs",
      "require": "./dist/cjs/*.cjs",
      "default": "./dist/esm/*.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tamagui-build --skip-types",
    "watch": "tamagui-build --skip-types --watch",
    "clean": "tamagui-build clean",
    "clean:build": "tamagui-build clean:build"
  },
  "devDependencies": {
    "@tamagui/build": "workspace:*",
    "react": ">=19",
    "react-native": "0.83.2"
  },
  "peerDependencies": {
    "@tamagui/animate-presence": "*",
    "@tamagui/avatar": "*",
    "@tamagui/button": "*",
    "@tamagui/checkbox": "*",
    "@tamagui/checkbox-headless": "*",
    "@tamagui/colors": "*",
    "@tamagui/config": "*",
    "@tamagui/context-menu": "*",
    "@tamagui/core": "*",
    "@tamagui/get-button-sized": "*",
    "@tamagui/image": "*",
    "@tamagui/input": "*",
    "@tamagui/linear-gradient": "*",
    "@tamagui/list-item": "*",
    "@tamagui/logo": "*",
    "@tamagui/lucide-icons": "*",
    "@tamagui/menu": "*",
    "@tamagui/popover": "*",
    "@tamagui/progress": "*",
    "@tamagui/radio-group": "*",
    "@tamagui/radio-headless": "*",
    "@tamagui/roving-focus": "*",
    "@tamagui/select": "*",
    "@tamagui/sheet": "*",
    "@tamagui/slider": "*",
    "@tamagui/stacks": "*",
    "@tamagui/switch": "*",
    "@tamagui/switch-headless": "*",
    "@tamagui/tabs": "*",
    "@tamagui/tamagui-dev-config": "*",
    "@tamagui/theme": "*",
    "@tamagui/toast": "*",
    "react": ">=19",
    "react-native": "*",
    "tamagui": "*"
  }
}
