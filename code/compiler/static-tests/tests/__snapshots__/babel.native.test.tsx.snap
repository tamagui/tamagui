    export function Test() {
      return (
        <__TamaguiNativeView style={{"flexDirection":"column"}}>
          <__TamaguiNativeView
            style={{"flexDirection":"column","backgroundColor":"red"}}

          />
        </__TamaguiNativeView>
      )
    }

const __TamaguiNativeView = require('react-native').View;"
`;

