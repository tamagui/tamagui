{
  "name": "@tamagui/animations-motion",
  "version": "2.5.1",
  "license": "MIT",
  "source": "src/index.ts",
  "files": [
    "src",
    "types",
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "polyfill.*"
  ],
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "react-native": {
        "types": "./types/index.native.d.ts",
        "default": "./dist/esm/index.native.js"
      },
      "types": "./types/index.d.ts",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tamagui-build",
    "watch": "tamagui-build --watch",
    "clean": "tamagui-build clean",
    "clean:build": "tamagui-build clean:build"
  },
  "dependencies": {
    "@tamagui/animation-helpers": "workspace:*",
    "@tamagui/use-presence": "workspace:*",
    "@tamagui/web": "workspace:*",
    "motion": ">=12.35.1"
  },
  "devDependencies": {
    "@tamagui/build": "workspace:*",
    "react": ">=19"
  },
  "peerDependencies": {
    "react": ">=19"
  }
}
