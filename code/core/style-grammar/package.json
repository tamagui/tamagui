{
  "name": "@tamagui/style-grammar",
  "version": "2.5.1",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "source": "src/index.ts",
  "files": [
    "src/index.ts",
    "src/candidate.ts",
    "src/config.ts",
    "src/registry.ts",
    "src/table.ts",
    "types",
    "dist"
  ],
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tamagui-build --exclude __tests__",
    "test": "vitest --run src"
  },
  "dependencies": {},
  "devDependencies": {
    "@tamagui/build": "workspace:*",
    "vitest": "4.0.4"
  }
}
