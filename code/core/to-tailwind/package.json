{
  "name": "@tamagui/to-tailwind",
  "version": "2.0.0-rc.31",
  "private": false,
  "main": "dist/index.cjs",
  "module": "dist/index.native.js",
  "source": "src/index.ts",
  "license": "MIT",
  "scripts": {
    "build": "tamagui-build",
    "test": "bun run build:test-deps && vitest --run",
    "test:web": "bun run build:test-deps && vitest --run",
    "build:test-deps": "bun run --cwd ../shorthands build && bun run --cwd ../config build"
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.25.4",
    "@babel/generator": "^7.25.5",
    "@babel/types": "^7.25.4",
    "@tamagui/config": "workspace:*",
    "@tamagui/helpers": "workspace:*",
    "@tamagui/shorthands": "workspace:*"
  },
  "devDependencies": {
    "vitest": "4.0.4"
  }
}
