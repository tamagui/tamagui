{
  "name": "@tamagui/scroll-view",
  "version": "2.5.1",
  "source": "src/index.ts",
  "files": [
    "src",
    "types",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./web": {
      "types": "./types/web.d.ts",
      "react-native": "./dist/esm/web.mjs",
      "browser": "./dist/esm/web.mjs",
      "module": "./dist/esm/web.mjs",
      "import": "./dist/esm/web.mjs",
      "require": "./dist/cjs/web.cjs",
      "default": "./dist/esm/web.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tamagui-build",
    "watch": "tamagui-build --watch",
    "clean": "tamagui-build clean",
    "clean:build": "tamagui-build clean:build"
  },
  "dependencies": {
    "@tamagui/web": "workspace:*"
  },
  "devDependencies": {
    "@tamagui/build": "workspace:*",
    "react": ">=19",
    "react-native": "0.83.2"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "module:jsx": "dist/jsx"
}
