{
  "compilerOptions": {
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "strict": false
  },
  "include": ["**/*.ts"]
}
