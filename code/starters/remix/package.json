{
  "name": "@tamagui/remix-starter",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build:web": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "prod": "bun run build:web && bun run start",
    "upgrade:tamagui": "bunx npm-check-updates -u '*tamagui*' '@tamagui/*' && bun install"
  },
  "dependencies": {
    "@react-router/node": "^7.18.0",
    "@react-router/serve": "^7.18.0",
    "@tamagui/config": "workspace:*",
    "react": ">=19",
    "react-dom": "*",
    "react-router": "^7.18.0",
    "tamagui": "workspace:*"
  },
  "devDependencies": {
    "@react-router/dev": "^7.18.0",
    "@react-router/fs-routes": "^7.18.0",
    "@tamagui/vite-plugin": "workspace:*",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "typescript": "~5.9.2",
    "vite": "^8.0.3",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.3.9",
  "version": "2.3.3"
}
